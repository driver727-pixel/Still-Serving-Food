# Firecrawl API key — get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Google Places API key (Legacy) — required for the hybrid discovery pipeline.
# When set, Phase 1 uses Google Places for clean entity verification instead of
# broad Firecrawl web search.  Enable the "Places API" in your Google Cloud project.
# https://developers.google.com/maps/documentation/places/web-service/overview
#
# Kitchen-specific secondary hours (Phase 1 enhancement):
# If your Google Cloud project also has the "Places API (New)" enabled, the pipeline
# will automatically attempt to fetch KITCHEN secondary hours for each venue — these
# are often more accurate than general opening hours.  No additional key is needed;
# the same GOOGLE_PLACES_API_KEY is used.  Failures are silently ignored so the
# pipeline always continues with the best available data.
# https://developers.google.com/maps/documentation/places/web-service/place-details
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Apify API key — RECOMMENDED for reliable Facebook and Instagram scraping.
# Without this key, Firecrawl is used as a best-effort fallback for Facebook
# (Phase 3a), and Instagram scraping (Phase 3b) is skipped entirely.
# Apify maintains browser fingerprint pools and session rotation specifically
# designed to circumvent social-media bot-detection.
# https://apify.com/apify/facebook-pages-scraper   (Phase 3a)
# https://apify.com/apify/instagram-scraper         (Phase 3b)
APIFY_API_KEY=your_apify_api_key_here

# Foursquare Places API key — OPTIONAL enrichment source (Phase 6).
# When set, venues that still have no hours after all other sources are tried
# are enriched with Foursquare structured hours and user-contributed tips.
# Create a free developer account and generate a v3 API key at:
# https://developer.foursquare.com/
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Server port (default: 3000)
PORT=3000

# PostgreSQL database URL — OPTIONAL for data persistence (CQRS pattern).
# When set, scrape results are persisted to a PostgreSQL ledger and read-optimized
# cache for the /api/v1/venues/open-now endpoint.
# Without this, the app falls back to in-memory caching (venueStore).
# Example: postgresql://user:password@host:5432/letsnarf
DATABASE_URL=

# Set to 'false' to disable SSL for local development PostgreSQL
DB_SSL=true

# JWT secret for business owner tokens — REQUIRED in production.
# Generate a strong random value, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BUSINESS_JWT_SECRET=
