# Firecrawl API key — get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Google Places API key (Legacy) — required for the hybrid discovery pipeline.
# When set, Phase 1 uses Google Places for clean entity verification instead of
# broad Firecrawl web search.  Enable the "Places API" in your Google Cloud project.
# https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Apify API key — RECOMMENDED for reliable Facebook page scraping (Phase 3).
# Without this key, Firecrawl is used as a best-effort fallback, but Facebook's
# bot-detection frequently blocks unauthenticated headless browsers.
# The apify/facebook-pages-scraper actor handles session rotation and fingerprint
# spoofing, making it the production-grade choice for Facebook extraction.
# https://apify.com/apify/facebook-pages-scraper
APIFY_API_KEY=your_apify_api_key_here

# Server port (default: 3000)
PORT=3000
