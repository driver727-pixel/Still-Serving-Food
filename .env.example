# Firecrawl API key — get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Server port (default: 3000)
PORT=3000

# ── Stripe (subscriber payments) ───────────────────────────────────────────────
# Stripe secret key — get yours at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret — from https://dashboard.stripe.com/webhooks
# Point the webhook at https://your-domain.com/api/stripe-webhook
# and subscribe to the checkout.session.completed event.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for the one-time $4.99 subscriber pass.
# Create a product + one-time price in Stripe dashboard, then paste the price ID here.
STRIPE_PRICE_ID=price_...

# Public URL of this app (used for Stripe redirect URLs)
APP_URL=https://letsnarf.com

# Secret used to sign subscriber JWT tokens — set to a long random string in production
SUBSCRIBER_SECRET=change-me-in-production
